    (effects (font (size 1.27 1.27)) (justify left bottom))
    (uuid 2ee15ee9-6ea3-4325-b9ad-3adbfd14f654)
  )
  (text "DTR=1 RTS=1 RST=1 IO0=1\nDTR=0 RTS=0 RST=1 IO0=1\nDTR=1 RTS=0 RST=0 IO0=1\nDTR=0 RTS=1 RST=1 IO0=0"
